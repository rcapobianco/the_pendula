     RowBox[{"w1", ",", "w2"}], "}"}], "=", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"WeierstrassHalfPeriods", "[", 
       RowBox[{"{", 
        RowBox[{"g2", ",", "g3"}], "}"}], "]"}], ",", "40"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v1", " ", "=", 
