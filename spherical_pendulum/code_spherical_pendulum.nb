Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "=="}], 
   "*)"}], 
  RowBox[{"(*", 
   RowBox[{"Numerical", " ", "animation", " ", 
    RowBox[{"(", "robust", ")"}]}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "===", "===", "===", "===", "===", "===", "===", "===", "===", "=="}], 
   "*)"}], 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "thetaNum", ",", "phiNum", ",", "xNum", ",", "yNum", ",", "zNum", ",", 
     "trajdataNum", ",", "trajindexNum", ",", "trajanimatedNum", ",", 
     "rodNum", ",", "bobNum", ",", "frameNum", ",", "framesNum"}], "]"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Extract", " ", "numerical", " ", "solutions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"thetaNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"\[Theta]", "[", "t", "]"}], "/.", " ", "sol"}], "]"}]}], "\n", 
   
   RowBox[{
    RowBox[{"phiNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Evaluate", "[", 
     RowBox[{
      RowBox[{"\[Phi]", "[", "t", "]"}], "/.", " ", "sol"}], "]"}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Cartesian", " ", "coordinates"}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"xNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"l", "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"thetaNum", "[", "t", "]"}], "]"}], "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"phiNum", "[", "t", "]"}], "]"}]}]}], "\n", 
   RowBox[{
    RowBox[{"yNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"l", "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"thetaNum", "[", "t", "]"}], "]"}], "*", 
     RowBox[{"Sin", "[", 
      RowBox[{"phiNum", "[", "t", "]"}], "]"}]}]}], "\n", 
   RowBox[{
    RowBox[{"zNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"-", "l"}], "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"thetaNum", "[", "t", "]"}], "]"}]}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Precompute", " ", "trajectory"}], "*)"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"trajdataNum", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xNum", "[", "t", "]"}], ",", 
         RowBox[{"yNum", "[", "t", "]"}], ",", 
         RowBox[{"zNum", "[", "t", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"tmax", "-", "t0"}], ")"}], "/", "300"}]}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"trajindexNum", "[", "t_", "]"}], ":=", 
     RowBox[{"Clip", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"t", "-", "t0"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"tmax", "-", "t0"}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Length", "[", "trajdataNum", "]"}], "-", "1"}], ")"}]}], 
         "]"}], "+", "1"}], ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Length", "[", "trajdataNum", "]"}]}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Animated", " ", "trajectory"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"trajanimatedNum", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Thick", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"trajdataNum", "[", 
          RowBox[{"[", 
           RowBox[{";;", 
            RowBox[{"trajindexNum", "[", "t", "]"}]}], "]"}], "]"}], "]"}]}], 
       "}"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", "Rod", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rodNum", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Black", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
           RowBox[{"trajdataNum", "[", 
            RowBox[{"[", 
             RowBox[{"trajindexNum", "[", "t", "]"}], "]"}], "]"}]}], "}"}], 
         "]"}]}], "}"}], "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", "Bob", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"bobNum", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"trajdataNum", "[", 
           RowBox[{"[", 
            RowBox[{"trajindexNum", "[", "t", "]"}], "]"}], "]"}], ",", 
          RowBox[{"0.05", " ", "l"}]}], "]"}]}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Frame", "*)"}], "\n", 
   RowBox[{
    RowBox[{"frameNum", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Show", "[", 
     RowBox[{"sphere", ",", 
      RowBox[{"trajanimatedNum", "[", "t", "]"}], ",", 
      RowBox[{"rodNum", "[", "t", "]"}], ",", 
      RowBox[{"bobNum", "[", "t", "]"}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "l"}], ",", "l"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "l"}], ",", "l"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "l"}], ",", "l"}], "}"}]}], "}"}]}], ",", 
      RowBox[{"Boxed", "->", "False"}], ",", 
      RowBox[{"ViewPoint", "->", "Front"}], ",", 
      RowBox[{"ViewVertical", "->", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ",", 
      RowBox[{"ViewCenter", "->", 
       RowBox[{"{", 
        RowBox[{"0.5", ",", "0.5", ",", "0.5"}], "}"}]}], ",", 
      RowBox[{"SphericalRegion", "->", "True"}], ",", 
      RowBox[{"ImageSize", "->", "400"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Generate", " ", "frames"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"framesNum", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"frameNum", "[", "t", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"tmax", "-", "t0"}], ")"}], "/", "200"}]}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Export", "*)"}], "\n", " ", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<spherical_pendulum_numerical.gif\>\"", ",", "framesNum"}], 
    "]"}], " ", "\[IndentingNewLine]", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<spherical_pendulum_numerical.mp4\>\"", ",", "framesNum", 
     ",", "\"\<MP4\>\""}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.983366634772979*^9, 3.983366644762508*^9}, {
