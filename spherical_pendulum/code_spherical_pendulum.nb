Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Well", ",", " ", 
    RowBox[{
    "at", " ", "this", " ", "point", " ", "we", " ", "need", " ", "to", " ", 
     "discuss", " ", "the", " ", "problem", " ", "with", " ", "this", " ", 
     RowBox[{"impleementation", ".", " ", "There"}], " ", "is", " ", "no", " ",
      "problem", " ", "at", " ", "all", " ", "with", " ", "the", " ", "final",
      " ", "expression", " ", "we", " ", "had", " ", "obtained", " ", "for", " ",
      "\[Phi]", 
     RowBox[{
      RowBox[{"(", "t", ")"}], ".", " ", "However"}]}], ",", " ", 
    RowBox[{
    "it", " ", "is", " ", "likely", " ", "that", " ", "the", " ", "plot", " ",
      "of", " ", "\[Phi]", 
     RowBox[{"(", "t", ")"}], " ", "may", " ", "not", " ", "look", " ", 
     "continous"}], ",", " ", 
    RowBox[{"as", " ", "it", " ", "shoud", " ", 
     RowBox[{"be", ".", " ", "The"}], " ", "real", " ", "problem", " ", "is", 
     " ", "that", " ", "\"\<Log\>\"", " ", "is", " ", "a", " ", "multi", " ", 
     "valued", " ", "function"}], ",", " ", 
    RowBox[{
    "and", " ", "to", " ", "properly", " ", "plot", " ", "the", " ", 
     "analytical", " ", "expression", " ", "we", " ", "had", " ", "for", " ", 
     "the", " ", "elliptic", " ", "integral", " ", "of", " ", "the", " ", 
     "third", " ", "kind", " ", "it", " ", "would", " ", "be", " ", 
     "required", " ", "the", " ", "function", " ", "to", " ", "choose", " ", 
     "the", " ", "proper", " ", "branch", " ", "of", " ", "the", " ", 
     RowBox[{"function", ".", " ", "A"}], " ", "test", " ", "to", " ", 
     "verify", " ", "that"}], ",", " ", 
    RowBox[{
     RowBox[{
     "is", " ", "to", " ", "just", " ", "see", " ", "that", " ", "different", 
      " ", "parts", " ", "obtained", " ", "from", " ", "the", " ", "above", " ",
       "plot", " ", "will", " ", "be", " ", "in", " ", "good", " ", 
      "agreement", " ", "by", " ", "doing", " ", "\[Phi]", 
      RowBox[{"(", "t", ")"}]}], " ", "->", " ", 
     RowBox[{
      RowBox[{"\[Phi]", 
       RowBox[{"(", "t", ")"}]}], " ", "+", " ", 
      RowBox[{"k", "*", 
       RowBox[{"\[Pi]", "."}]}]}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]"}]], "Input",
