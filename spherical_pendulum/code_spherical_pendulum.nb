           "y1"}], ",", 
          RowBox[{"{", 
           RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "*", 
        RowBox[{"WeierstrassSigma", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            SqrtBox[
             RowBox[{"2", 
              SuperscriptBox["\[Omega]0", "2"]}]], "t0"}], "-", "u0", "+", 
           "y1"}], ",", 
          RowBox[{"{", 
