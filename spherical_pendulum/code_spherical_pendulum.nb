Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Next", " ", "step", " ", "is", " ", "to", " ", "animate", " ", "the", " ", 
     RowBox[{"motion", ".", " ", "The"}], " ", "easiest", " ", "way", " ", 
     "would", " ", "be", " ", "to", " ", "use", " ", "the", " ", "numerical", 
     " ", "solution"}], ",", " ", 
    RowBox[{
    "which", " ", "was", " ", "already", " ", "tested", " ", "and", " ", 
     "produces", " ", "the", " ", "same", " ", "final", " ", "output", " ", 
     "as", " ", "the", " ", "analytical", " ", 
     RowBox[{"approach", ".", " ", "However"}]}], ",", " ", 
    RowBox[{
    "we", " ", "are", " ", "not", " ", "taking", " ", "that", " ", 
     "approach"}], ",", " ", 
    RowBox[{"instead", " ", 
     RowBox[{"let", "'"}], "s", " ", "built", " ", "everything", " ", "from", 
     " ", "our", " ", "analytical", 
     RowBox[{"(", "ish", ")"}], " ", 
     RowBox[{"functions", ".", " ", "Note"}]}], ",", " ", "however", ",", " ", 
    RowBox[{
    "that", " ", "for", " ", "larger", " ", "tmax", " ", "values", " ", 
     "this", " ", "can", " ", "be", " ", "quite", " ", "long", " ", 
     RowBox[{
     "proccess", ".", " ", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      "To"}], " ", "make", " ", "the", " ", "animation", " ", "working", " ", 
     "properly", " ", "one", " ", "needs", " ", "to", " ", "first", " ", 
     "create", " ", "the", " ", "data", " ", "instead", " ", "of", " ", 
     "making", " ", "Mathematica", " ", "calculate", " ", "within", " ", 
     "the", " ", "animation", " ", 
     RowBox[{"enviroment", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "trajdata", ",", "trajindex", ",", "trajanimated", ",", "rod", ",", 
     "bob"}], "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"trajdata", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"x", "[", "t", "]"}], ",", 
         RowBox[{"y", "[", "t", "]"}], ",", 
         RowBox[{"z", "[", "t", "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax", ",", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"tmax", "-", "t0"}], ")"}], "/", "300"}]}], "}"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"trajindex", "[", "t_", "]"}], ":=", 
     RowBox[{"Clip", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"t", "-", "t0"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"tmax", "-", "t0"}], ")"}]}], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Length", "[", "trajdata", "]"}], "-", "1"}], ")"}]}], 
         "]"}], "+", "1"}], ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"Length", "[", "trajdata", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Creating", " ", "the", " ", "trajajectory", " ", "from", " ", "the", " ", 
     RowBox[{"data", "."}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"trajanimated", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", "Thick", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"trajdata", "[", 
          RowBox[{"[", 
           RowBox[{";;", 
            RowBox[{"trajindex", "[", "t", "]"}]}], "]"}], "]"}], "]"}]}], 
       "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Creating", " ", "the", " ", "rod"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rod", "[", 
      RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Graphics3D", "[", 
      RowBox[{"{", 
       RowBox[{"Black", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", 
           RowBox[{"trajdata", "[", 
            RowBox[{"[", 
             RowBox[{"trajindex", "[", "t", "]"}], "]"}], "]"}]}], "}"}], 
         "]"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bob", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Graphics3D", "[", 
     RowBox[{"{", 
      RowBox[{"Red", ",", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"trajdata", "[", 
          RowBox[{"[", 
           RowBox[{"trajindex", "[", "t", "]"}], "]"}], "]"}], ",", 
         RowBox[{"0.05", " ", "l"}]}], "]"}]}], "}"}], "]"}]}], "\n", 
   "\[IndentingNewLine]", "\n"}]}]], "Input",
 CellChangeTimes->{{3.977312520538281*^9, 3.9773125476244783`*^9}, {
