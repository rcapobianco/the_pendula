Cell[BoxData[
 RowBox[{
  RowBox[{"sphere", " ", "=", " ", 
   RowBox[{"Graphics3D", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Opacity", "[", "0.1", "]"}], ",", "Red", ",", 
      RowBox[{"Sphere", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}], ",", "l"}], "]"}]}], "}"}],
     "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9772717893121233`*^9, 3.977271811535417*^9}, {
  3.97727346854235*^9, 3.977273529463732*^9}, {3.977273604755835*^9, 
  3.977273631617693*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"472ade49-d589-44b8-9d80-d00c43ba8ce3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Animation", ",", " ", 
    RowBox[{"just", " ", "for", " ", "fun"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"x", ",", "y", ",", "z", ",", "orbit"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"l", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"theta", "[", "t", "]"}], "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"phi", "[", "t", "]"}], "]"}]}], "//", "Chop"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"l", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"theta", "[", "t", "]"}], "]"}], "*", 
      RowBox[{"Sin", "[", 
       RowBox[{"phi", "[", "t", "]"}], "]"}]}], "//", "Chop"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z", "[", 
     RowBox[{"t_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "l"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"theta", "[", "t", "]"}], "]"}]}], "//", "Chop"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"orbit", " ", "=", " ", 
     RowBox[{"ParametricPlot3D", "[", 
      RowBox[{
       RowBox[{"Re", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", 
          RowBox[{"y", "[", "t", "]"}], ",", 
          RowBox[{"z", "[", "t", "]"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax"}], "}"}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<x\>\"", ",", "\"\<y\>\"", ",", "\"\<z\>\""}], "}"}]}]}],
       "]"}]}], ";"}]}]}]], "Input",
