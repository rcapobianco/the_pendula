Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Here", " ", "we", " ", "do", " ", "a", " ", "numerical", " ", 
    "integration", " ", "of", " ", "the", " ", "equations", " ", "of", " ", 
    RowBox[{"motion", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "lagrangean", ",", "eom\[Theta]", ",", "eom\[Phi]", ",", "sol", ",", 
     "ICs", ",", "\[Theta]", ",", "\[Phi]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lagrangean", " ", "=", " ", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"m", "*", 
         SuperscriptBox["l", "2"]}], "2"], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{
           RowBox[{"\[Theta]", "'"}], "[", "t", "]"}], "2"], "+", 
         RowBox[{
          SuperscriptBox[
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "[", "t", "]"}], "]"}], "2"], "*", 
          SuperscriptBox[
           RowBox[{
            RowBox[{"\[Phi]", "'"}], "[", "t", "]"}], "2"]}]}], ")"}]}], "-", 
      
      RowBox[{"m", "*", "g", "*", "l", "*", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"Cos", "[", 
          RowBox[{"\[Theta]", "[", "t", "]"}], "]"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eom\[Theta]", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"lagrangean", ",", 
          RowBox[{
           RowBox[{"\[Theta]", "'"}], "[", "t", "]"}]}], "]"}], ",", "t"}], 
       "]"}], " ", "-", " ", 
      RowBox[{"D", "[", 
       RowBox[{"lagrangean", ",", 
        RowBox[{"\[Theta]", "[", "t", "]"}]}], "]"}]}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eom\[Phi]", "=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{"lagrangean", ",", 
          RowBox[{
           RowBox[{"\[Phi]", "'"}], "[", "t", "]"}]}], "]"}], ",", "t"}], 
       "]"}], " ", "-", " ", 
      RowBox[{"D", "[", 
       RowBox[{"lagrangean", ",", 
        RowBox[{"\[Phi]", "[", "t", "]"}]}], "]"}]}]}], " ", ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"ICs", "=", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Theta]", "[", "0", "]"}], "==", "\[Theta]0"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Theta]", "'"}], "[", "0", "]"}], "==", "v\[Theta]0"}], ",", 
        RowBox[{
         RowBox[{"\[Phi]", "[", "0", "]"}], "==", "\[Phi]0"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Phi]", "'"}], "[", "0", "]"}], "==", "v\[Phi]0"}]}], 
       "}"}], ",", "40"}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"sol", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"eom\[Theta]", "==", "0"}], ",", 
         RowBox[{"eom\[Phi]", "==", "0"}], ",", "ICs"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Phi]"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax"}], "}"}]}], "]"}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"ClearAll", "[", 
    RowBox[{"num\[Theta]plot", ",", "num\[Phi]plot"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"num\[Theta]plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{
         RowBox[{"\[Theta]", "[", "t", "]"}], "/.", "sol"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "t0", ",", "tmax"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Red", ",", "Dashed"}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", "All"}]}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"num\[Phi]plot", " ", "=", " ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
