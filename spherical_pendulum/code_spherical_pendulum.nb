Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"phi", ",", "exact\[Phi]int"}], "]"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phi", "[", 
    RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x0", ",", "x1"}], "}"}], ",", "\[IndentingNewLine]", 
     "\t\t\t\t\t\t", 
     RowBox[{
      RowBox[{"x0", "=", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           SuperscriptBox["\[Omega]0", "2"]}]], " ", "t0"}], "-", "u0"}]}], ";",
       "\[IndentingNewLine]", "\t\t\t\t\t\t", 
      RowBox[{"x1", "=", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"2", " ", 
           SuperscriptBox["\[Omega]0", "2"]}]], " ", "t"}], "-", "u0"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"Re", "[", 
       RowBox[{"\[Phi]0", "+", 
        RowBox[{
         RowBox[{"\[Alpha]", "/", "8"}], "*", 
         RowBox[{"NIntegrate", "[", 
          RowBox[{
           RowBox[{
            FractionBox["1", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"WeierstrassP", "[", 
                RowBox[{"x", ",", 
                 RowBox[{"{", 
                  RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", "v1"}], 
              ")"}]], "-", 
            FractionBox["1", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"WeierstrassP", "[", 
                RowBox[{"x", ",", 
                 RowBox[{"{", 
                  RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}], "-", "v2"}], 
              ")"}]]}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "x0", ",", "x1"}], "}"}], ",", 
           "\[IndentingNewLine]", "\t\t\t\t\t", 
           RowBox[{"WorkingPrecision", "->", "MachinePrecision"}], ",", 
           RowBox[{"AccuracyGoal", "->", "10"}], ",", 
           RowBox[{"PrecisionGoal", "->", "10"}]}], "]"}]}]}], "]"}]}]}], 
    "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{"exact\[Phi]int", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"phi", "[", "t", "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "t0", ",", "tmax"}], "}"}], ",", 
    RowBox[{"AxesLabel", "->", 
     RowBox[{"{", 
      RowBox[{"\"\<t\>\"", ",", "\"\<\[Phi](t)\>\""}], "}"}]}]}], 
   "]"}]}], "\n"}], "Input",
