Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Exact", " ", "\[Theta]"}], "-", "motion"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "v0", ",", " ", "u0", ",", "u", ",", "theta", ",", "exact\[Theta]plot"}], 
    "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"v0", " ", "=", " ", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["1", "4"]}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Cos", "[", "\[Theta]0", "]"}], "+", 
        FractionBox[
         RowBox[{"\[Xi]", "-", "1"}], "3"]}], ")"}]}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"u0", " ", "=", "  ", 
     RowBox[{
      RowBox[{
       SqrtBox[
        RowBox[{"2", 
         SuperscriptBox["\[Omega]0", "2"]}]], "*", "t0"}], "  ", "-", " ", 
      RowBox[{"sign", "*", 
       RowBox[{"InverseWeierstrassP", "[", 
        RowBox[{"v0", ",", 
         RowBox[{"{", 
          RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"u", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "4"}], "*", 
        RowBox[{"WeierstrassP", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             SqrtBox[
              RowBox[{"2", "*", 
               SuperscriptBox["\[Omega]0", "2"]}]], "*", "t"}], "-", "u0"}], 
           ")"}], ",", 
          RowBox[{"{", 
           RowBox[{"g2", ",", "g3"}], "}"}]}], "]"}]}], "-", 
       FractionBox[
        RowBox[{"(", 
         RowBox[{"\[Xi]", "-", "1"}], ")"}], "3"]}], "]"}], "//", "Chop"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"theta", "[", "t_", "]"}], " ", "=", " ", 
     RowBox[{"ArcCos", "[", 
      RowBox[{"u", "[", "t", "]"}], "]"}]}], " ", ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"exact\[Theta]plot", "=", 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"theta", "[", "t", "]"}], ",", 
        RowBox[{"Callout", "[", 
         RowBox[{"\[Theta]min", ",", "\"\<\[Theta]min\>\"", ",", 
          RowBox[{"{", 
           RowBox[{"\[Pi]", ",", "\[Theta]min"}], "}"}]}], "]"}], ",", 
        RowBox[{"Callout", "[", 
         RowBox[{"\[Theta]max", ",", "\"\<\[Theta]max\>\"", ",", 
          RowBox[{"{", 
           RowBox[{"\[Pi]", ",", "\[Theta]max"}], "}"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "t0", ",", "tmax"}], "}"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Black", ",", "Dashed"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Black", ",", "Dashed"}], "}"}]}], "}"}]}], ",", 
      "\[IndentingNewLine]", "\t\t\t\t", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<t\>\"", ",", "\"\<\[Theta](t)\>\""}], "}"}]}], ",", 
      RowBox[{"PlotRange", "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Theta]min", "-", ".3"}], ",", 
         RowBox[{"\[Theta]max", "+", ".3"}]}], "}"}]}]}], 
     "]"}]}]}]}]], "Input",
