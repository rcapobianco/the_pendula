Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{
   "w1", ",", "w2", ",", "v1", ",", "v2", ",", "y1", ",", "y2", ",", "phi1", ",",
     "phi2", ",", "exactphi", ",", "exact\[Phi]plot"}], "]"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
